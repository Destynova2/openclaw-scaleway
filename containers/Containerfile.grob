# grob — LLM routing proxy with built-in DLP (~15 MB, scratch-based).
# Multi-model routing, budget management, secret scanning, PII detection.
# Build: podman build -t grob -f Containerfile.grob containers/
FROM docker.io/alpine:3.21 AS fetcher
RUN apk add --no-cache curl
ARG GROB_VERSION=v0.9.0
RUN curl -fsSL "https://github.com/azerozero/grob/releases/download/${GROB_VERSION}/grob-${GROB_VERSION}-x86_64-unknown-linux-musl.tar.gz" \
    | tar xz -C /usr/local/bin grob

FROM scratch
COPY --from=fetcher /usr/local/bin/grob /grob
COPY --from=fetcher /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
USER 1000
ENTRYPOINT ["/grob"]

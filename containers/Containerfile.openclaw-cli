# openclaw-cli — CLI sidecar for gateway communication via websocket.
# Runs as exec target inside the pod. See CLAUDE.md "Communication" section.
# Build: podman build -t openclaw-cli -f Containerfile.openclaw-cli containers/
FROM docker.io/node:22-alpine

# renovate: datasource=npm depName=openclaw
ARG OPENCLAW_VERSION=2026.2.26

# --ignore-scripts : skip node-llama-cpp native build (inutile en mode CLI remote)
RUN apk add --no-cache git && \
    npm install -g openclaw@${OPENCLAW_VERSION} --ignore-scripts && \
    npm cache clean --force && \
    apk del git

# Meme UID que le pod (runAsUser: 1000)
USER 1000

ENTRYPOINT ["tail", "-f", "/dev/null"]
